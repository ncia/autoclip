# AI-Clip Stream Backend Environment Variables

# Server
PORT=8000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://admin:password@localhost:5432/aiclip

# Redis (for Celery workers)
REDIS_URL=redis://localhost:6379/0

# OpenAI API Key (Required for Whisper and GPT)
OPENAI_API_KEY=your_openai_api_key_here

# YouTube Data API Key (Optional, for uploading)
YOUTUBE_API_KEY=your_youtube_api_key_here
